{
  "name": "enterprise-ecommerce-playwright-framework",
  "version": "1.0.0",
  "description": "Enterprise-level Playwright Test automation framework for an e-commerce website.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:dev": "cross-env TEST_ENV=dev playwright test",
    "test:staging": "cross-env TEST_ENV=staging playwright test",
    "test:prod": "cross-env TEST_ENV=production playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:sanity": "playwright test --grep @sanity",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report"
  },
  "keywords": [
    "playwright",
    "automation",
    "ecommerce",
    "pom",
    "javascript"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@playwright/test": "^1.45.3",
    "allure-commandline": "^2.29.0",
    "allure-playwright": "^3.0.0-beta.10",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5"
  }
}
